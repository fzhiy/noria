# Embeddings cache (large, regenerable)
.kb/embeddings/

# Local tool binaries (installed, not tracked)
.codex-tools/
.codex

# Python
__pycache__/
*.pyc
.venv/

# Obsidian workspace
.obsidian/

# OS
.DS_Store
Thumbs.db

# Secrets
.env
*.key

# Temporary
*.tmp
*.bak
*.stackdump

# Handoff artifacts (ephemeral)
handoff/

# ARIS meta logs (local only)
# .aris/meta/events.jsonl is tracked for meta-optimize
.aris/meta/backups/
.aris/meta/optimizations.jsonl
wiki.wsl-backup-*
tools/.twitter-cookies.txt

# WeChat Docker runtime data
tools/wechat/data/

# Auto-generated Canvas (deprecated — use Juggl/sigma.js instead)
wiki/*.canvas
wiki/canvas/
nohup.out

# /implement intermediate files (specs, logs)
.ai/
.gitleaks.toml

# Review loop artifacts
AUTO_REVIEW.md
REVIEW_STATE.json

# Runtime state (user-specific)
.kb/manifest.json
