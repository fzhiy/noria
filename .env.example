# NORIA — Environment Variables
# Copy to .env and fill in your values

# === Required for full functionality ===

# Semantic Scholar API (free, get at https://api.semanticscholar.org/)
SEMANTIC_SCHOLAR_API_KEY=

# Zotero (for /kb-sync zotero and /kb-deepen PDF access)
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_COLLECTION_KEY=

# Zotero local paths (WSL2 example — adjust for your system)
ZOTERO_DB=/path/to/zotero.sqlite
ZOTERO_ATTACHMENT_BASE=/path/to/zotero/storage

# === Optional ===

# DeepXiv API (for /kb-trending and cloud paper reading)
DEEPXIV_TOKEN=

# GitHub (increases rate limit from 60 to 5000 req/hr)
GITHUB_TOKEN=

# WeChat RSS Docker service
WE_MP_RSS_USER=admin
WE_MP_RSS_PASS=change-me

# Remote MCP service (for /serve-remote.sh)
NORIA_REMOTE=user@your-remote-host
NORIA_REMOTE_DIR=/path/to/noria
